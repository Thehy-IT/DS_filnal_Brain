# BrainTumorAI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to git (it's already in .gitignore).

# ---------------------------------------------------------------------------
# Data paths (optional — defaults to data/Training and data/Testing)
# ---------------------------------------------------------------------------
# DATA_DIR=D:/path/to/your/Training
# TEST_DIR=D:/path/to/your/Testing

# ---------------------------------------------------------------------------
# Training
# ---------------------------------------------------------------------------
# MODEL_NAME=efficientnet
# BATCH_SIZE=32
# EPOCHS=30

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------
# MODEL_DIR=models
# REPORTS_DIR=reports
# MODEL_PATH=models/efficientnet_best.pth

# ---------------------------------------------------------------------------
# API Server
# ---------------------------------------------------------------------------
# API_HOST=127.0.0.1
# API_PORT=8000

# Comma-separated list of allowed CORS origins
# ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000
